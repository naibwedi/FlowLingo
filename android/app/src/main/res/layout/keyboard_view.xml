<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/keyboard_canvas"
    android:orientation="vertical"
    android:paddingStart="3dp"
    android:paddingTop="3dp"
    android:paddingEnd="3dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/keyboard_surface_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="9dp"
        android:paddingTop="6dp"
        android:paddingEnd="7dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/activeLanguagePair"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/keyboard_pair_chip_background"
                    android:paddingStart="9dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/keyboard_ink"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/previewStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textColor="@color/keyboard_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/translationSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:minHeight="32dp"
                android:textColor="@color/keyboard_ink"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/applyTranslationButton"
            style="@style/KeyboardCompactActionButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/apply_translation_description"
            android:enabled="false"
            android:src="@drawable/ic_keyboard_apply" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="q|1|[" android:text="q" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="w|2|]" android:text="w" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="e|3|{" android:text="e" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="r|4|}" android:text="r" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="t|5|#" android:text="t" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="y|6|%" android:text="y" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="u|7|^" android:text="u" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="i|8|*" android:text="i" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="o|9|+" android:text="o" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="p|0|=" android:text="p" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="0.18" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="a|@|_" android:text="a" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="s|/|\\" android:text="s" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="d|(|&lt;" android:text="d" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="f|)|&gt;" android:text="f" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="g|&amp;|~" android:text="g" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="h|-|`" android:text="h" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="j|'|:" android:text="j" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="k|&quot;|;" android:text="k" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="l|!|?" android:text="l" />
        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="0.18" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/keyShift"
            style="@style/KeyboardUtilityButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="2dp"
            android:layout_weight="1.22"
            android:text="@string/key_shift" />

        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="z|,|." android:text="z" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="x|?|/" android:text="x" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="c|:|!" android:text="c" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="v|;|&quot;" android:text="v" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="b|$|#" android:text="b" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="n|*|_" android:text="n" />
        <Button style="@style/KeyboardKeyButton" android:layout_width="0dp" android:layout_height="46dp" android:layout_margin="2dp" android:layout_weight="1" android:tag="m|+|=" android:text="m" />

        <Button
            android:id="@+id/keyBackspace"
            style="@style/KeyboardUtilityButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="2dp"
            android:layout_weight="1.3"
            android:text="@string/key_backspace_short" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/keySymbols"
            style="@style/KeyboardUtilityButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:layout_weight="1.05"
            android:text="@string/key_symbols" />

        <Button
            style="@style/KeyboardKeyButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:layout_weight="0.9"
            android:tag=",|,|&lt;"
            android:text="," />

        <Button
            android:id="@+id/keySpace"
            style="@style/KeyboardKeyButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:layout_weight="6.3"
            android:contentDescription="@string/spacebar_description"
            android:text="" />

        <Button
            style="@style/KeyboardKeyButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:layout_weight="0.9"
            android:tag=".|.|&gt;"
            android:text="." />

        <ImageButton
            android:id="@+id/keyEnter"
            style="@style/KeyboardActionIconButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_margin="2dp"
            android:layout_weight="1.1"
            android:contentDescription="@string/key_enter_description"
            android:src="@drawable/ic_keyboard_enter" />
    </LinearLayout>
</LinearLayout>
