<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#ECE6D9"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:minHeight="52dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/translationSuggestion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="#17352C" />

        <Button
            android:id="@+id/applyTranslationButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:enabled="false"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/apply_translation" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="q|1" android:text="q" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="w|2" android:text="w" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="e|3" android:text="e" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="r|4" android:text="r" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="t|5" android:text="t" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="y|6" android:text="y" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="u|7" android:text="u" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="i|8" android:text="i" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="o|9" android:text="o" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="p|0" android:text="p" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="0.4" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="a|@" android:text="a" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="s|#" android:text="s" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="d|$" android:text="d" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="f|%" android:text="f" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="g|&amp;" android:text="g" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="h|*" android:text="h" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="j|(" android:text="j" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="k|)" android:text="k" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="l|/" android:text="l" />
        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="0.4" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/keyShift"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="1.4"
            android:text="@string/key_shift" />

        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="z|&quot;" android:text="z" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="x|'" android:text="x" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="c|:" android:text="c" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="v|;" android:text="v" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="b|!" android:text="b" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="n|?" android:text="n" />
        <Button android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="3dp" android:layout_weight="1" android:tag="m|-" android:text="m" />

        <Button
            android:id="@+id/keyBackspace"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="1.6"
            android:text="@string/key_backspace_short" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/keySymbols"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="1.3"
            android:text="@string/key_symbols" />

        <Button
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:tag=",|,"
            android:text="," />

        <Button
            android:id="@+id/keySpace"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="4.4"
            android:text="@string/key_space_short" />

        <Button
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:tag=".|."
            android:text="." />

        <Button
            android:id="@+id/keyEnter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_margin="3dp"
            android:layout_weight="1.5"
            android:text="@string/key_enter" />
    </LinearLayout>
</LinearLayout>
