<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_special_key_caps" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_special_key_active" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_special_key_pressed" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_special_key" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/keyboard_key_border" />
        </shape>
    </item>
</selector>
